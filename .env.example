# ─── AWS / S3 / CloudFront (Frontend) ────────────────────────────────────────
AWS_REGION=us-east-1
AWS_PROFILE=                          # Optional: named AWS CLI profile
S3_BUCKET_NAME=yourdomain.com         # S3 bucket name (usually your domain)
SITE_DOMAIN=yourdomain.com            # Your custom domain (for display)
BUILD_DIR=dist                        # Vite build output directory
CLOUDFRONT_DISTRIBUTION_ID=           # e.g. E1234567890ABC (leave blank to skip)

# ─── AWS Lambda (Backend) ─────────────────────────────────────────────────────
LAMBDA_FUNCTION_NAME=ttt-backend      # Lambda function name
LAMBDA_ZIP=lambda-backend.zip         # Temp zip file name
LAMBDA_RUNTIME=nodejs18.x             # Lambda runtime
LAMBDA_HANDLER=server.handler         # Entry point: file.exportedFunction
LAMBDA_TIMEOUT=30                     # Seconds
LAMBDA_MEMORY=512                     # MB
API_GATEWAY_ID=                       # HTTP API Gateway ID (e.g. abc123def)

# ─── Frontend env (also set in .env.local) ────────────────────────────────────
# VITE_API_URL=https://<API_GATEWAY_ID>.execute-api.<REGION>.amazonaws.com/api

# ─── Backend env (also set in backend/.env) ───────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/ttt?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here_min_32_chars
CLIENT_URL=https://yourdomain.com

# Firebase Admin SDK
FIREBASE_PROJECT_ID=tribesoftravellers-4e611
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tribesoftravellers-4e611.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
