{
  "name": "ttt-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "seed": "node scripts/seed.js",
    "seed:hotels": "node scripts/seedHotels.js",
    "seed:all": "node scripts/seed.js && node scripts/seedHotels.js",
    "setup:collections": "node scripts/setupCollections.js",
    "package:lambda": "zip -r ../lambda-backend.zip . -x 'node_modules/.cache/*' -x '.env' -x '.git/*'",
    "build:lambda": "npm ci --omit=dev && npm run package:lambda"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^12.2.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "razorpay": "^2.9.2",
    "serverless-http": "^3.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.3"
  }
}
